// ═════════════════════════════════════════════════════════════════════════════
// FIREBASE STORAGE SECURITY RULES
// File: storage.rules
//
// Copy these rules into Firebase Console → Storage → Rules
// ═════════════════════════════════════════════════════════════════════════════

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // PDF files stored under: pdfs/{userId}/{fileName}
    match /pdfs/{userId}/{allPaths=**} {

      // READ: Only the file owner can read their files
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // WRITE (upload/update): Only the owner, PDF only, max 20MB
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 20 * 1024 * 1024;

      // DELETE: Only the owner can delete their files
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Block all other paths
    match /{allOtherPaths=**} {
      allow read, write: if false;
    }
  }
}


// ═════════════════════════════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES
// File: firestore.rules
//
// Copy these rules into Firebase Console → Firestore Database → Rules
